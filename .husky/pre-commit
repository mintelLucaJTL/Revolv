#!/usr/bin/env sh

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
#
# Normalize paths so Windows-git paths like `RevolvAPI\Program.cs`
# still match our `/` based prefixes.
#
STAGED=$(git diff --cached --name-only --diff-filter=ACMR | tr '\\' '/')

frontend_changed=false
backend_changed=false

echo "$STAGED" | grep -q '^Frontend/' && frontend_changed=true
echo "$STAGED" | grep -q '^RevolvAPI/' && backend_changed=true

if [ "$frontend_changed" = false ] && [ "$backend_changed" = false ]; then
  echo "[pre-commit] No Frontend or RevolvAPI changes staged. Skipping checks."
  exit 0
fi

echo "[pre-commit] Running quality checks..."

if [ "$frontend_changed" = true ]; then
  echo "[frontend] Linting..."
  (cd "$ROOT/Frontend" && node ./node_modules/oxlint/bin/oxlint) || {
    echo "[frontend] Lint failed. Fix the reported issues and try again."
    exit 1
  }

  echo "[frontend] Verifying formatting..."
  (cd "$ROOT/Frontend" && node ./node_modules/oxfmt/bin/oxfmt --check) || {
    echo "[frontend] Formatting check failed. Run: cd Frontend && npm run format"
    exit 1
  }
fi

if [ "$backend_changed" = true ]; then
  echo "[backend] Verifying C# formatting..."
  (cd "$ROOT/RevolvAPI" && dotnet format RevolvAPI.csproj --verify-no-changes) || {
    echo "[backend] Formatting check failed. Run: cd RevolvAPI && dotnet format RevolvAPI.csproj"
    exit 1
  }

  echo "[backend] Verifying C# compilation..."
  (cd "$ROOT/RevolvAPI" && dotnet build RevolvAPI.csproj -v:m) || {
    echo "[backend] Build failed. Fix the C# errors and try again."
    exit 1
  }
fi

echo "[pre-commit] All checks passed."
